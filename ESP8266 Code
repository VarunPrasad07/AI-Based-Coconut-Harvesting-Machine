#include <ESP8266WiFi.h>
#include <ESP8266WebServer.h>
#include <Servo.h>
#include <KiwisIoT.h>

// ===== WIFI =====
const char* ssid  = "NaNcY";
const char* pass  = "nancy2404";
const char* topic = "dash_1773908397794";

KiwisIoT kiwisiot(ssid, pass, topic);
ESP8266WebServer server(80);


// ===== SERVO =====
Servo myServo1;
Servo myServo2;
int currentPos1 = 90;
int currentPos2 = 90;

// ===== MOTOR PINS =====
#define IN1 D1
#define IN2 D2
#define IN3 D3
#define IN4 D4
#define RELAY D0   

// ===== TRIGGER CONTROL =====
bool coconutTriggered = false;
unsigned long lastTriggerTime = 0;
const unsigned long cooldown = 5000; // 5 sec

// -------- SMOOTH MOVE --------
void smoothMove(Servo &srv, int &currentPos, int target, int stepDelay = 20) {
  target = constrain(target, 0, 180);

  if (currentPos < target) {
    for (int pos = currentPos; pos <= target; pos++) {
      srv.write(pos);
      delay(stepDelay);
    }
  } else {
    for (int pos = currentPos; pos >= target; pos--) {
      srv.write(pos);
      delay(stepDelay);
    }
  }
  currentPos = target;
}

// -------- MOTOR CONTROL --------
void motorForward() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}
void motorReverse() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}
void motorRight() {
  digitalWrite(IN1, HIGH);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, HIGH);
}
void motorLeft() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, HIGH);
  digitalWrite(IN3, HIGH);
  digitalWrite(IN4, LOW);
}
void motorStop() {
  digitalWrite(IN1, LOW);
  digitalWrite(IN2, LOW);
  digitalWrite(IN3, LOW);
  digitalWrite(IN4, LOW);
}

// -------- AUTO ACTION --------
void coconutAction() {
  Serial.println("🥥 Coconut Detected → AUTO ACTION");

  motorStop();  // 🔥 stop motors before servo

  digitalWrite(RELAY, LOW);   // ON

  smoothMove(myServo1, currentPos1, 0);
  delay(1500);
  smoothMove(myServo1, currentPos1, 90);

  digitalWrite(RELAY, HIGH);  // OFF
}

// -------- HTTP TRIGGER --------
void handleCoconut() {
  unsigned long now = millis();

  // 🔒 prevent repeated trigger
  if (coconutTriggered && (now - lastTriggerTime < cooldown)) {
    server.send(200, "text/plain", "IGNORED");
    return;
  }

  coconutTriggered = true;
  lastTriggerTime = now;

  coconutAction();

  server.send(200, "text/plain", "DONE");
}

// -------- IOT CONTROL --------
void onControl(String ch, String val) {

  val.trim();

  Serial.print("CH=");
  Serial.print(ch);
  Serial.print(" VAL=");
  Serial.println(val);

  if (ch == "2") {
    if (val == "1") digitalWrite(RELAY, LOW);
    else if (val == "0") digitalWrite(RELAY, HIGH);
  }

  else if (ch == "0") {
    if      (val == "forward") motorForward();
    else if (val == "back")    motorReverse();
    else if (val == "right")   motorRight();
    else if (val == "left")    motorLeft();
    else if (val == "stop")    motorStop();
  }

  else if (ch == "1") {
    if (val == "forward") smoothMove(myServo1, currentPos1, 0);
    else if (val == "back") smoothMove(myServo1, currentPos1, 90);
    else if (val == "right") smoothMove(myServo2, currentPos2, 0);
    else if (val == "left") smoothMove(myServo2, currentPos2, 90);
  }
}

// -------- SETUP --------
void setup() {
  Serial.begin(115200);

  pinMode(IN1, OUTPUT);
  pinMode(IN2, OUTPUT);
  pinMode(IN3, OUTPUT);
  pinMode(IN4, OUTPUT);
  motorStop();

  pinMode(RELAY, OUTPUT);
  digitalWrite(RELAY, HIGH);

  myServo1.attach(D5);
  myServo2.attach(D6);
  myServo1.write(90);
  myServo2.write(90);

  kiwisiot.begin();
  kiwisiot.onReceive(onControl);

  // HTTP trigger
  server.on("/coconut", handleCoconut);
  server.begin();
}

// -------- LOOP --------
void loop() {
  kiwisiot.run();
  server.handleClient();
}
